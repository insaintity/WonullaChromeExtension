{
  "manifest_version": 3,
  "name": "Wonulla Watch Tracker",
  "description": "Stores the last video and playback position watched on wonulla.to.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": ["*://wonulla.to/*", "*://*.wonulla.to/*"],
  "content_scripts": [
    {
      "matches": ["*://wonulla.to/*", "*://*.wonulla.to/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Wonulla Watch Tracker",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
